{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/og", "destination": "/api/og.js" },
    { "source": "/api/ride-og", "destination": "/api/ride-og.js" },
    { "source": "/api/ride-hero", "destination": "/api/ride-hero.js" }
  ]
}
