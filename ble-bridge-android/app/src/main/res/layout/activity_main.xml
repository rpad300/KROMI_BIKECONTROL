<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#030712">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BikeControl BLE Bridge"
            android:textSize="18sp"
            android:textColor="#00E676"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/wsClientsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WS: 0"
            android:textSize="11sp"
            android:textColor="#6B7280"
            android:background="#1F2937"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"/>
    </LinearLayout>

    <!-- SCAN — big prominent button -->
    <Button
        android:id="@+id/connectBtn"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:text="SCAN FOR DEVICES"
        android:textSize="20sp"
        android:backgroundTint="#00E676"
        android:textColor="#000000"
        android:textStyle="bold"/>

    <!-- Disconnect + Unbond row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/disconnectBtn"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="DISCONNECT"
            android:textSize="12sp"
            android:backgroundTint="#EF4444"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/unbondBtn"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="UNBOND"
            android:textSize="12sp"
            android:backgroundTint="#374151"
            android:textColor="#F59E0B"/>
    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Disconnected"
        android:textSize="14sp"
        android:textColor="#9CA3AF"
        android:paddingHorizontal="12dp"
        android:paddingBottom="6dp"/>

    <!-- Services -->
    <TextView
        android:id="@+id/servicesText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bat:- CSC:- Pwr:- SG:- GEV:- Proto:- HR:-"
        android:textSize="12sp"
        android:textColor="#6B7280"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp"
        android:fontFamily="monospace"/>

    <!-- Sensors -->
    <TextView
        android:id="@+id/sensorsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Baro:- Light:- Lean:- Temp:-"
        android:textSize="12sp"
        android:textColor="#6B7280"
        android:paddingHorizontal="12dp"
        android:paddingBottom="6dp"
        android:fontFamily="monospace"/>

    <!-- SG test buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/testSGBtn"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="TEST SG"
            android:textSize="14sp"
            android:backgroundTint="#F59E0B"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/listenBtn"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="LISTEN 30s"
            android:textSize="14sp"
            android:backgroundTint="#8B5CF6"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/sgOnlyBtn"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="SG ONLY"
            android:textSize="14sp"
            android:backgroundTint="#EC4899"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Motor control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/assistDownBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="ASSIST ▼"
            android:textSize="14sp"
            android:backgroundTint="#3B82F6"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/assistUpBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="ASSIST ▲"
            android:textSize="14sp"
            android:backgroundTint="#10B981"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/lightBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="LIGHT"
            android:textSize="13sp"
            android:backgroundTint="#6366F1"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/setTuningBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="TUNING"
            android:textSize="13sp"
            android:backgroundTint="#F59E0B"
            android:textColor="#000000"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="6dp">

        <Button
            android:id="@+id/testBtn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="BLE TEST"
            android:textSize="11sp"
            android:backgroundTint="#1F2937"
            android:textColor="#FCD34D"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/copyLogBtn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="COPY LOG"
            android:textSize="11sp"
            android:backgroundTint="#1F2937"
            android:textColor="#60A5FA"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/clearLogBtn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="CLEAR"
            android:textSize="11sp"
            android:backgroundTint="#1F2937"
            android:textColor="#9CA3AF"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1F2937"/>

    <!-- Log Console -->
    <ScrollView
        android:id="@+id/logScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0A0A0A"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#6B7280"
            android:fontFamily="monospace"
            android:lineSpacingExtra="1dp"
            android:textIsSelectable="true"/>
    </ScrollView>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ws://localhost:8765 — Open kromi.online"
        android:textSize="10sp"
        android:textColor="#4B5563"
        android:gravity="center"
        android:padding="6dp"
        android:background="#0F0F0F"/>
</LinearLayout>
