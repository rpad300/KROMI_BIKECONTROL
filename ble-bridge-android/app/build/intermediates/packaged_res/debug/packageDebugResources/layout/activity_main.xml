<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#030712">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BikeControl"
        android:textSize="32sp"
        android:textColor="#00E676"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BLE Bridge"
        android:textSize="18sp"
        android:textColor="#9CA3AF"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/connectBtn"
        android:layout_width="240dp"
        android:layout_height="64dp"
        android:text="Connect Bike"
        android:textSize="18sp"
        android:backgroundTint="#00E676"
        android:textColor="#000000"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:id="@+id/wsStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WebSocket: ws://localhost:8765"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Open kromi.online in Chrome to use"
        android:textSize="14sp"
        android:textColor="#6B7280"/>
</LinearLayout>
