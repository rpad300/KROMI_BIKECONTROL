# === Google Maps ===
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# === Google Drive (OAuth 2.0 — for file storage) ===
# Create at https://console.cloud.google.com/apis/credentials
# Type: "OAuth 2.0 Client ID" → "Web application"
# Authorized JavaScript origins must include: http://localhost:5173, https://localhost:5173,
# your Vercel URL, and production domain. NEVER commit the client_secret.
VITE_GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com

# === Simulation Mode ===
# Set to true for development without bike hardware
VITE_SIMULATION_MODE=false

# === Supabase (profile sync + ride history) ===
